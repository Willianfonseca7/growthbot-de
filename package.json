{
  "name": "growthbot-de",
  "version": "1.0.0",
  "description": "Telegram-based LLM sales assistant for the DACH market",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:bot": "tsx watch src/bot.ts",
    "build": "next build",
    "start": "next start",
    "bot:start": "tsx src/bot.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project unit --project integration",
    "test:watch": "vitest",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:coverage": "vitest run --project unit --project integration --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e",
    "telegram:webhook:set": "node scripts/telegram-webhook.mjs set",
    "telegram:webhook:info": "node scripts/telegram-webhook.mjs info",
    "telegram:webhook:delete": "node scripts/telegram-webhook.mjs delete"
  },
  "keywords": [
    "telegram",
    "llm",
    "sales-assistant",
    "affiliate",
    "growthbot"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "next": "^15.5.2",
    "node-telegram-bot-api": "^0.67.0",
    "openai": "^6.35.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.3.0",
    "@types/node-telegram-bot-api": "^0.64.8",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitest/coverage-v8": "^3.2.7",
    "jsdom": "^29.1.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
